{
  "name": "@martinez/mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "format": "prettier . --write"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@gorhom/bottom-sheet": "^5.2.14",
    "@react-navigation/bottom-tabs": "^7.16.0",
    "@react-navigation/elements": "^2.9.17",
    "@react-navigation/native": "^7.2.4",
    "@tanstack/react-form": "^1.32.0",
    "@tanstack/react-query": "^5.100.10",
    "expo": "~55.0.24",
    "expo-build-properties": "~55.0.14",
    "expo-constants": "~55.0.16",
    "expo-dev-client": "~55.0.33",
    "expo-device": "~55.0.17",
    "expo-font": "~55.0.7",
    "expo-glass-effect": "~55.0.11",
    "expo-image": "~55.0.10",
    "expo-linking": "~55.0.15",
    "expo-network": "~55.0.14",
    "expo-router": "~55.0.14",
    "expo-splash-screen": "~55.0.21",
    "expo-status-bar": "~55.0.6",
    "expo-symbols": "~55.0.8",
    "expo-system-ui": "~55.0.18",
    "expo-web-browser": "~55.0.16",
    "heroui-native": "^1.0.3",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.1",
    "react-native-keyboard-controller": "~1.21.7",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.24.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "~0.21.2",
    "react-native-worklets": "0.7.4",
    "superjson": "^2.2.6",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.3.0",
    "uniwind": "^1.6.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/jest": "29.5.14",
    "@types/node": "^25.7.0",
    "@types/react": "~19.2.14",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~55.0.1",
    "eslint-config-prettier": "^10.1.8",
    "jest": "~29.7.0",
    "jest-expo": "~55.0.17",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "connect": "^3.7.0",
    "serve-sim": "^0.1.28",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3"
  },
  "private": true,
  "expo": {
    "install": {
      "exclude": [
        "@react-navigation/bottom-tabs",
        "@react-navigation/native",
        "react-native-keyboard-controller",
        "react-native-screens"
      ]
    }
  },
  "jest": {
    "preset": "jest-expo",
    "roots": ["<rootDir>/tests"],
    "setupFiles": ["<rootDir>/tests/testing-utils/jest-setup.ts"],
    "setupFilesAfterEnv": ["<rootDir>/tests/testing-utils/jest-after-env.ts"],
    "collectCoverage": true,
    "collectCoverageFrom": [
      "src/**/*.{ts,tsx,js,jsx}",
      "!src/**/*.d.ts",
      "!src/**/*.test.{ts,tsx,js,jsx}",
      "!src/**/*.spec.{ts,tsx,js,jsx}",
      "!src/**/index.{ts,tsx,js,jsx}"
    ],
    "coverageDirectory": "coverage/app",
    "coverageReporters": ["text-summary", "lcov"],
    "testMatch": ["<rootDir>/tests/**/*.test.[jt]s?(x)"],
    "transformIgnorePatterns": [
      "node_modules/(?!(?:((jest-)?react-native|@react-native(-community)?|expo(nent)?|@expo(nent)?/.*|react-navigation|@react-navigation/.*|native-base|react-native-svg|react-native-worklets|react-native-reanimated|react-native-keyboard-controller|react-native-gesture-handler|react-native-safe-area-context|heroui-native|uniwind|tailwind-variants|superjson|copy-anything|is-what)))"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1",
      "^@tests/(.*)$": "<rootDir>/tests/$1"
    }
  }
}
