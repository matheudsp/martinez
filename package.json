{
  "name": "martinez",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "nx run-many -t dev -p mobile server",
    "dev:server": "bun run --cwd apps/server dev",
    "dev:mobile": "bun run --cwd apps/mobile start",
    "deploy:server": "bun run --cwd apps/server deploy",
    "lint:mobile": "bun run --cwd apps/mobile lint",
    "typecheck:mobile": "bun run --cwd apps/mobile typecheck",
    "format": "bun run --cwd apps/mobile format"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "nx": "23.0.0"
  }
}